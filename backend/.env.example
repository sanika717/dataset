# Copy this file to .env and fill in real values before running locally
# without Docker. When running via `docker-compose up`, these are set
# directly in docker-compose.yml instead — this file is only read when
# you run uvicorn/alembic directly on your host machine.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sitesafe
JWT_SECRET_KEY=change-me-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
